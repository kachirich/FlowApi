# Server
PORT=3000
NODE_ENV=production

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=flow_gateway
PGUSER=postgres
PGPASSWORD=new_password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# JWT
JWT_SECRET=change_me_to_a_long_random_string

# Webhooks
GHL_WEBHOOK_SECRET=your_ghl_secret_here
# Optional: External destination to forward leads to during simulation/testing
DESTINATION_WEBHOOK_URL=https://your-downstream-tool.com/webhook

# CORS — comma-separated allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
