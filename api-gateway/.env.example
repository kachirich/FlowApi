# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in every CHANGE_ME value before running.
# NEVER commit .env — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# BASE_URL — public-facing URL of the API Gateway. Used to build webhook URLs.
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# JWT — generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=7d

# Resend — transactional email API key (https://resend.com)
RESEND_API_KEY=CHANGE_ME

# DATABASE (DOCKER INTERNAL)
PGHOST=pgbouncer
PGPORT=6432
PGUSER=postgres
PGPASSWORD=CHANGE_ME
PGDATABASE=postgres

# PgBouncer (same creds, different var names the bitnami image expects)
POSTGRESQL_USERNAME=postgres
POSTGRESQL_PASSWORD=CHANGE_ME
POSTGRESQL_DATABASE=flowapi_gateway
POSTGRESQL_HOST=pg-db
PGBOUNCER_POOL_MODE=transaction

# REDIS / RATE LIMITING (DOCKER INTERNAL)
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# LEMON SQUEEZY
LEMON_SQUEEZY_API_KEY=CHANGE_ME
LEMON_SQUEEZY_WEBHOOK_SECRET=CHANGE_ME

# Google OAuth — create credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# SMTP fallback (optional, used if Resend is not configured)
EMAIL_USER=CHANGE_ME
EMAIL_PASS=CHANGE_ME

# Webhooks
GHL_WEBHOOK_SECRET=CHANGE_ME
DESTINATION_WEBHOOK_URL=http://localhost:3000/api/auth/guest

# Localhost destination whitelist (for self-hosted integrations like OpenWA / n8n
# on the same host). SSRF protection is bypassed only when BOTH conditions hold:
#   1. The acting user's email is in LOCALHOST_WHITELIST_EMAILS
#   2. The target host:port is in LOCALHOST_WHITELIST_HOSTS
# Comma-separated, case-insensitive. Leave blank to disable the bypass entirely.
LOCALHOST_WHITELIST_EMAILS=support.flowapi@gmail.com
LOCALHOST_WHITELIST_HOSTS=localhost:5678,localhost:8080
