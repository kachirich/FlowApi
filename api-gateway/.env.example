# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in every CHANGE_ME value before running.
# NEVER commit .env — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# BASE_URL — public-facing URL of the API Gateway. Used to build webhook URLs.
# Falls back to http://localhost:PORT in development.
BASE_URL=https://your-production-domain.com
FRONTEND_URL=https://your-frontend-domain.com

# PostgreSQL (PgBouncer port is 6432, direct Postgres is 5432/5433)
PGHOST=localhost
PGPORT=6432
PGDATABASE=flow_gateway
PGUSER=postgres
PGPASSWORD=CHANGE_ME

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# JWT — generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=7d

# ENCRYPTION_KEY — AES-256-GCM key for encrypting destination API tokens at rest.
# Must be exactly 64 hex characters (32 bytes). The server refuses to start
# without a valid value. Generate with:  openssl rand -hex 32
# NEVER change this once tokens are stored — rotating it makes them undecryptable.
ENCRYPTION_KEY=CHANGE_ME

# Webhooks
# GHL_WEBHOOK_SECRET — secret used to verify GoHighLevel webhook signatures
GHL_WEBHOOK_SECRET=CHANGE_ME
# Optional: downstream destination for testing/simulation
DESTINATION_WEBHOOK_URL=https://your-downstream-tool.com/webhook

# CORS — comma-separated allowed frontend origins
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Google OAuth 2.0 — create credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_CALLBACK_URL=https://your-production-domain.com/api/auth/google/callback

# Resend — transactional email API key (https://resend.com)
RESEND_API_KEY=CHANGE_ME

# SMTP fallback (optional, used if Resend is not configured)
EMAIL_USER=CHANGE_ME
EMAIL_PASS=CHANGE_ME

# LemonSqueezy / Stripe billing webhook secret
LEMON_SQUEEZY_WEBHOOK_SECRET=CHANGE_ME
