{
  "name": "api-gateway",
  "version": "1.0.0",
  "description": "Secure API Gateway with Express, Helmet, rate limiting, and PostgreSQL request logging",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "seed": "node db/seed.js",
    "test": "vitest run --reporter verbose",
    "test:watch": "vitest --reporter verbose"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.77.3",
    "cors": "^2.8.6",
    "disposable-email-blocklist": "^0.0.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "otplib": "^13.4.0",
    "pg": "^8.13.1",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^5.0.0",
    "redis": "^5.12.1",
    "resend": "^6.12.4",
    "speakeasy": "^2.0.0",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^1.6.0"
  }
}
